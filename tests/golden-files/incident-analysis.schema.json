{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://incidentpilot.local/schemas/incident-analysis-v1.json",
  "title": "IncidentAnalysisJSON",
  "type": "object",
  "required": [
    "schema_version",
    "incident_id",
    "service",
    "severity",
    "status",
    "summary",
    "current_status",
    "evidence",
    "evidence_gaps",
    "hypotheses",
    "recommendations",
    "verification_plan",
    "follow_up_actions",
    "llm_status",
    "rules_only"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "incident_id": {"type": "integer", "minimum": 1},
    "service": {"type": "string", "minLength": 1},
    "severity": {
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {"const": "diagnosed"},
    "summary": {"type": "string"},
    "current_status": {"type": "string"},
    "evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence"}
    },
    "evidence_gaps": {
      "type": "array",
      "items": {"type": "string"}
    },
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/hypothesis"}
    },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/recommendation"}
    },
    "verification_plan": {
      "type": "array",
      "items": {"type": "string"}
    },
    "follow_up_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "llm_status": {
      "enum": ["not_requested", "available", "unavailable"]
    },
    "rules_only": {"type": "boolean"}
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["ref", "type", "source", "summary"],
      "properties": {
        "ref": {"type": "string", "pattern": "^evidence:[0-9]+$"},
        "type": {"type": "string"},
        "source": {"type": "string"},
        "summary": {"type": "string"}
      },
      "additionalProperties": false
    },
    "hypothesis": {
      "type": "object",
      "required": [
        "rank",
        "cause",
        "confidence",
        "evidence_refs",
        "reasoning"
      ],
      "properties": {
        "rank": {"type": "integer", "minimum": 1},
        "cause": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "reasoning": {"type": "string"}
      },
      "additionalProperties": false
    },
    "recommendation": {
      "type": "object",
      "required": [
        "action_key",
        "title",
        "rationale",
        "requires_approval",
        "allowed_by_policy",
        "execution_enabled_in_mvp",
        "executed"
      ],
      "properties": {
        "action_key": {"type": "string"},
        "title": {"type": "string"},
        "rationale": {"type": "string"},
        "requires_approval": {"type": "boolean"},
        "allowed_by_policy": {"type": "boolean"},
        "execution_enabled_in_mvp": {"const": false},
        "executed": {"const": false}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
